keywords:
  - "stochastic partial differential equations"
  - "Chebyshev collocation"
  - "exponential integrators"
  - "ETDRK4"
  - "Talbot contour"
  - "Ornstein-Uhlenbeck noise"
  - "stochastic Allen-Cahn"
  - "stochastic Burgers"
